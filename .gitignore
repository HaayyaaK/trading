# OS / editor
desktop.ini
Thumbs.db
.vscode/
*.swp

# Node / Python tooling
node_modules/
__pycache__/
*.pyc

# generated artifacts (rebuilt by tests / tools)
test/mine.json
tools/seeds.json

# stray pre-existing file (inert duplicate of this ignore file, kept on disk)
gitignore

# Local vendor libraries live in assets/ as large source trees. Commit ONLY the
# specific built files the app actually loads (so a fresh clone is deployable),
# and ignore the rest of each tree.
# Chart.js: unused (its local dist/ was never built) — ignore entirely.
assets/Chart.js-v4.5.1/
# ECharts: keep only the minified build the page loads.
assets/echarts-v6.1.0/**
!assets/echarts-v6.1.0/dist/
!assets/echarts-v6.1.0/dist/echarts.min.js
# FontAwesome: keep the aggregate CSS + the webfont files it @font-faces.
assets/fontawesome-free-v7.3.1-web/**
!assets/fontawesome-free-v7.3.1-web/css/
!assets/fontawesome-free-v7.3.1-web/css/all.min.css
!assets/fontawesome-free-v7.3.1-web/webfonts/
!assets/fontawesome-free-v7.3.1-web/webfonts/*.woff2
